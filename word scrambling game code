import random

def scramble_word(word):
    word_list = list(word)
    random.shuffle(word_list)
    return ''.join(word_list)

def play_game():
    words = ["python", "computer", "science", "programming", "developer",
             "keyboard", "internet", "software", "hardware", "algorithm"]

    score = 0
    attempts_allowed = 3

    print("🎮 Welcome to the Word Scrambling Game!")
    print("You have", attempts_allowed, "attempts to guess the correct word.\n")

    while True:
        word = random.choice(words)
        scrambled = scramble_word(word)

        print("Scrambled word:", scrambled)

        attempts = 0
        guessed_correctly = False

        while attempts < attempts_allowed:
            guess = input("Your guess: ").lower()

            if guess == word:
                print("✅ Correct! You earn 10 points.\n")
                score += 10
                guessed_correctly = True
                break
            else:
                attempts += 1
                print("❌ Incorrect! Attempts left:", attempts_allowed - attempts)

        if not guessed_correctly:
            print("😢 The correct word was:", word, "\n")

        print("Current Score:", score)

        play_again = input("\nDo you want to play again? (yes/no): ").lower()
        if play_again != "yes":
            print("\n🏁 Final Score:", score)
            print("Thanks for playing!")
            break

if __name__ == "__main__":
    play_game()
